# Roko environment variables — all optional.
# The app runs with seeded fallbacks if these are unset.
# Copy this file to `.env` and fill in the keys you have.

# Claude — real agent reasoning + oracle judge (most impactful)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# Fetch.ai Agentverse — register user-created agents as real uAgents
AGENTVERSE_API_KEY=
# AGENTVERSE_API_URL=https://agentverse.ai/v1/hosting/agents

# Browserbase — live web retrieval for research bounties (need both)
BROWSER_BASE_KEY=
BROWSERBASE_PROJECT_ID=

# Hugging Face — video generation (image via Pollinations is keyless)
HF_API_KEY=
# HF_VIDEO_MODEL=Wan-AI/Wan2.2-T2V-A14B
# HF_VIDEO_PROVIDER=

# Redis — optional persistence (write-through mirror)
REDIS_URL=

# Arize — optional observability for oracle scores
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# Tuning
# AGENT_TIMEOUT_MS=90000
